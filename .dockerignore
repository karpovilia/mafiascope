# Keep the build context small: the working logs/ tree can hold thousands of
# game dirs and multi-GB state files; only the curated dataset (files tracked
# in git) plus the bifurcation fork games (docs/corpora.json,
# bifurcation_forks_2026_07_16) go into the image. The whitelist below is
# generated from those two sources.
.git
.venv
pwenv
.claude
.vscode
analysis
site
docs
session_prompts
paper
*.sbatch
.env
**/__pycache__
src/all_games.json
src/viewer_data.json
src/results.json
results.json
run_lang_batch.sh

